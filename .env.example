APP_NAME=LexInsight Backend
APP_VERSION=0.1.0
APP_DEBUG=false
POSTGRES_USER=lexinsight
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lexinsight
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

ES_URL=http://localhost:9200
ES_REQUEST_TIMEOUT_S=10

# GigaChat (Сбер). Получите credentials на developers.sber.ru, положите
# значения в .env (никогда — в .env.example и не коммитьте). Свободный
# тариф — scope=GIGACHAT_API_PERS, модель=GigaChat (Lite, ~8K контекст).
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
